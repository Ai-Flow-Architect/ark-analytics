# Streamlit Cloud の「Secrets」にこの内容をコピーして設定してください
# （secrets.toml 実体は .gitignore で除外 — GitHubにpushしない）

# ① OpenAI API キー
OPENAI_API_KEY = "sk-proj-xxxxxxxxxxxxxxxxxxxx"

# ② GCP サービスアカウント（BigQuery 接続用）
# GCPコンソール → IAM → サービスアカウント → キーをJSONで作成
# JSONファイルの内容をそのまま以下に貼り付ける
[gcp_service_account]
type = "service_account"
project_id = "ark-hd-analytics"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN RSA PRIVATE KEY-----\nxxxxxxxxxx\n-----END RSA PRIVATE KEY-----\n"
client_email = "ark-analytics@ark-hd-analytics.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/ark-analytics%40ark-hd-analytics.iam.gserviceaccount.com"
