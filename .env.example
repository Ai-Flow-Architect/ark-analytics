# ============================================
# ark-analytics - 環境変数テンプレート
# ============================================
# このファイルを `.env` にコピーして実値を記入してください
#
# 使い方:
#   cp .env.example .env
#   # 各値を埋めたあと:
#   streamlit run app.py
#
# 本番環境では Streamlit Cloud Secrets を使用（.env は使わない）

# --- GCP / BigQuery ---
# GA4データを格納しているGCPプロジェクト
GOOGLE_CLOUD_PROJECT=
ARK_GCP_PROJECT_ID=
# GA4プロパティID（数値・例: 123456789）
ARK_GA4_PROPERTY_ID=
# BigQueryのデータセット名（例: analytics_xxxxx）
ARK_GA4_RAW_DATASET=
# サービスアカウント認証用のアクセストークン（CI/CDで使用）
GOOGLE_ACCESS_TOKEN=

# --- OpenAI ---
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# プロジェクト固有のOpenAIキー（任意・OPENAI_API_KEYと同値でも可）
ARK_OPENAI_API_KEY=

# --- Gmail SMTP（レポート配信用） ---
GMAIL_ADDRESS=
# Googleアプリパスワード: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# --- レポート配信先 ---
# クライアントメールアドレス
ARK_CLIENT_EMAIL=
# CC: カンマ区切りで複数指定可能
ARK_CC_EMAILS=

# --- Google Drive（レポート保存先） ---
# folder_token（共有フォルダのID）
ARK_DRIVE_FOLDER_ID=

# --- Lark通知（任意・処理完了通知用） ---
LARK_APP_ID=
LARK_APP_SECRET=
LARK_CHAT_ID=
